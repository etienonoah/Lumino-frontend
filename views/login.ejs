<!DOCTYPE html>
<html>
<body>

<h2>Login</h2>

<% if (errors && errors.length) { %>
  <% errors.forEach(e => { %>
    <p style="color:red"><%= e %></p>
  <% }) %>
<% } %>

<form action="/login" method="POST">
  <input name="username" placeholder="Username" required />
  <input type="password" name="password" placeholder="Password" required />
  <button>Login</button>
</form>

</body>
</html>